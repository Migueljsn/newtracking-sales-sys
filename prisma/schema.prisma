// Portal CRM — Schema Prisma
// Gerado com base nas decisões de arquitetura documentadas em memoria.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANT
// ─────────────────────────────────────────────────────────────────────────────

model Client {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  leadCaptureKey String   @unique @default(cuid())
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  settings          ClientSettings?
  user              User?
  consultantUsers   ConsultantUser[]
  customers         Customer[]
  leads             Lead[]
  sales             Sale[]
  trackingEvents    TrackingEvent[]
  notifications     Notification[]
  authorizedDomains AuthorizedDomain[]
  emailTemplates    EmailTemplate[]
  ltvEmailConfig    LtvEmailConfig?
  ltvEmailLogs      LtvEmailLog[]
  pipelineStages    PipelineStage[]
  audiences         Audience[]
  journeys          Journey[]
  leadInteractions  LeadInteraction[]
  journeyNodeLogs   JourneyNodeLog[]
}

model AuthorizedDomain {
  id        String   @id @default(cuid())
  clientId  String
  url       String
  label     String?
  createdAt DateTime @default(now())

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, url])
  @@index([clientId])
}

model ClientSettings {
  id                String   @id @default(cuid())
  clientId          String   @unique

  // Meta Conversions API
  metaPixelId                       String?
  metaAccessToken                   String?
  metaTestEventCode                 String?
  trackingEnabled                   Boolean  @default(true)

  // Consultores / vendedores
  consultants                       String[] @default([])

  // Mensagem padrão WhatsApp (variáveis: {nome}, {estado}, {cidade})
  whatsappTemplate                  String?

  // Google Ads Conversions API
  googleAdsEnabled                  Boolean  @default(false)
  googleAdsCustomerId               String?  // ex: 123-456-7890
  googleAdsConversionActionLead     String?  // ID numérico da ação de conversão Lead
  googleAdsConversionActionPurchase String?  // ID numérico da ação de conversão Purchase
  googleRefreshToken                String?  // OAuth2 refresh token

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  client            Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// CONSULTOR — acesso restrito à view operacional de leads
// ─────────────────────────────────────────────────────────────────────────────

model ConsultantUser {
  id           String   @id @default(cuid())
  clientId     String
  name         String
  email        String
  passwordHash String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, email])
  @@index([clientId])
}

// ─────────────────────────────────────────────────────────────────────────────
// USUÁRIO — um por client (CLIENT) ou sem client (ADMIN)
// ─────────────────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  CLIENT
}

model User {
  id         String    @id @default(cuid())
  clientId   String?   @unique  // null para ADMIN
  authUserId String    @unique  // ID do Supabase Auth
  email      String    @unique
  name       String
  role       UserRole  @default(CLIENT)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  client     Client?   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// CUSTOMER — o comprador real (entidade central)
// ─────────────────────────────────────────────────────────────────────────────

model Customer {
  id        String            @id @default(cuid())
  clientId  String
  name      String
  phone     String
  email     String?
  document  String?           // CPF ou CNPJ
  zipCode   String?
  city      String?
  state     String?           // sigla: SP, RJ...
  lifecycle CustomerLifecycle @default(NEW_BUYER)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  client    Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  leads     Lead[]
  sales     Sale[]
  ltvEmailLogs LtvEmailLog[]

  // mesma pessoa não pode aparecer duas vezes no mesmo cliente
  @@unique([clientId, phone])
  @@unique([clientId, document])
  @@index([clientId])
}

enum CustomerLifecycle {
  NEW_BUYER  // primeiro compra
  LOYAL      // comprou mais de uma vez
  CHAMPION   // alto volume ou frequência
  AT_RISK    // sem compra há muito tempo
  INACTIVE   // sem compra há muito mais tempo
}

// ─────────────────────────────────────────────────────────────────────────────
// LEAD — a oportunidade comercial
// ─────────────────────────────────────────────────────────────────────────────

model Lead {
  id             String      @id @default(cuid())
  clientId       String
  customerId     String
  status         LeadStatus  @default(NEW)
  source         LeadSource  @default(FORM)

  // UTMs — imutáveis após captura
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  utmContent     String?
  utmTerm        String?

  // Parâmetros Meta — capturados no frontend
  fbc            String?     // Facebook Click ID (não hashear)
  fbp            String?     // Facebook Browser ID (não hashear)
  gclid          String?     // Google Click ID (não hashear)
  eventSourceUrl String?     // URL da landing page no momento da captura

  // IDs do Meta Ads (via parâmetros customizados na URL)
  metaCampaignId String?
  metaAdsetId    String?
  metaAdId       String?

  consultant     String?     // nome do consultor/vendedor responsável
  notes          String?
  capturedAt     DateTime    @default(now()) // pode ser sobrescrito em importações
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  pipelineStageId String?
  pipelineStage   PipelineStage? @relation(fields: [pipelineStageId], references: [id])

  client              Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  customer            Customer            @relation(fields: [customerId], references: [id])
  sales               Sale[]
  statusHistory       LeadStatusHistory[]
  trackingEvents      TrackingEvent[]
  journeyEnrollments  JourneyEnrollment[]
  checklists          LeadChecklist[]

  interactions        LeadInteraction[]

  @@index([clientId])
  @@index([customerId])
  @@index([status])
}

enum LeadStatus {
  NEW        // recém capturada, aguardando primeiro contato
  REGISTERED // @deprecated — use pipeline stages instead; kept for backward compat
  SOLD       // venda registrada
  LOST       // descartada em qualquer etapa do funil
}

enum LeadSource {
  FORM    // formulário público de captura
  MANUAL  // criada manualmente no CRM
  IMPORT  // importada via XLSX
}

model LeadStatusHistory {
  id        String   @id @default(cuid())
  leadId    String
  from      String?
  to        String
  changedBy String?
  createdAt DateTime @default(now())

  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

model PipelineStage {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  color     String   @default("#6366f1")
  position  Int      @default(0)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client       Client                     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  leads        Lead[]
  requirements PipelineStageRequirement[]

  @@index([clientId])
}

model PipelineStageRequirement {
  id        String   @id @default(cuid())
  stageId   String
  text      String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  stage  PipelineStage   @relation(fields: [stageId], references: [id], onDelete: Cascade)
  checks LeadChecklist[]

  @@index([stageId])
}

model LeadChecklist {
  id            String    @id @default(cuid())
  leadId        String
  requirementId String
  checked       Boolean   @default(false)
  checkedAt     DateTime?
  checkedBy     String?

  lead        Lead                     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  requirement PipelineStageRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@unique([leadId, requirementId])
  @@index([leadId])
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIENCE — segmentação dinâmica de leads
// ─────────────────────────────────────────────────────────────────────────────

model Audience {
  id          String    @id @default(cuid())
  clientId    String
  name        String
  description String?
  rules       Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  journeys    Journey[]

  @@index([clientId])
}

// ─────────────────────────────────────────────────────────────────────────────
// JOURNEY — automações visuais de leads
// ─────────────────────────────────────────────────────────────────────────────

model Journey {
  id          String        @id @default(cuid())
  clientId    String
  name        String
  description String?
  status      JourneyStatus @default(DRAFT)
  audienceId  String?
  nodes       Json          @default("[]")
  edges       Json          @default("[]")
  sendWindow  Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client      Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  audience    Audience?           @relation(fields: [audienceId], references: [id])
  enrollments JourneyEnrollment[]
  nodeLogs    JourneyNodeLog[]

  @@index([clientId])
}

model JourneyEnrollment {
  id          String           @id @default(cuid())
  journeyId   String
  leadId      String
  currentNode String
  status      EnrollmentStatus @default(ACTIVE)
  startedAt   DateTime         @default(now())
  completedAt DateTime?

  journey     Journey          @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  lead        Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  nodeLogs    JourneyNodeLog[]

  @@unique([journeyId, leadId])
  @@index([journeyId])
  @@index([leadId])
}

model JourneyNodeLog {
  id           String   @id @default(cuid())
  enrollmentId String
  journeyId    String
  leadId       String
  clientId     String
  nodeId       String
  nodeType     String
  executedAt   DateTime @default(now())
  result       String?  // "advanced", "completed", "condition_true", "condition_false", "email_sent", "email_skipped", etc.

  enrollment   JourneyEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  journey      Journey           @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  client       Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([enrollmentId])
  @@index([journeyId])
  @@index([leadId])
  @@index([clientId])
}

enum JourneyStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  FAILED
  EXITED
}

// ─────────────────────────────────────────────────────────────────────────────
// SALE — venda confirmada
// ─────────────────────────────────────────────────────────────────────────────

model Sale {
  id               String   @id @default(cuid())
  clientId         String
  customerId       String
  leadId           String
  value            Decimal  @db.Decimal(10, 2)
  isRepeatPurchase Boolean  @default(false)
  notes            String?
  soldAt           DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  client           Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  customer         Customer @relation(fields: [customerId], references: [id])
  lead             Lead     @relation(fields: [leadId], references: [id])
  items            SaleItem[]
  trackingEvents   TrackingEvent[]

  @@index([clientId])
  @@index([customerId])
}

model SaleItem {
  id       String  @id @default(cuid())
  saleId   String
  name     String
  quantity Int     @default(1)
  price    Decimal @db.Decimal(10, 2)

  sale     Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────────────────────────────────────
// TRACKING — eventos para Meta Conversions API
// ─────────────────────────────────────────────────────────────────────────────

model TrackingEvent {
  id            String              @id @default(cuid())
  clientId      String
  eventName     TrackingEventName
  eventId       String              @unique  // usado para deduplicação no Meta
  status        TrackingEventStatus @default(PENDING)
  payload       Json                // payload completo que será enviado
  response      Json?               // resposta da API do Meta
  errorMessage  String?
  attempts      Int                 @default(0)
  lastAttemptAt DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  leadId        String?
  saleId        String?

  client        Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead          Lead?               @relation(fields: [leadId], references: [id])
  sale          Sale?               @relation(fields: [saleId], references: [id])

  @@index([clientId, status])
  @@index([eventName, status])
}

enum TrackingEventName {
  Lead
  Purchase
  GoogleLead
  GooglePurchase
}

enum TrackingEventStatus {
  PENDING   // aguardando envio
  SUCCESS   // enviado com sucesso
  FAILED    // falhou após todas as tentativas
  SKIPPED   // não enviado intencionalmente (ex: lead duplicada)
}

// ─────────────────────────────────────────────────────────────────────────────
// NOTIFICATION — alertas operacionais para o cliente
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id         String               @id @default(cuid())
  clientId   String
  type       NotificationType
  title      String
  body       String?
  isRead     Boolean              @default(false)
  metadata   Json?                // dados extras (ex: leadId, eventId, erro)
  dedupeKey  String?              @unique
  createdAt  DateTime             @default(now())

  client     Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, isRead])
}

enum NotificationType {
  TRACKING_ERROR        // falha no envio para o Meta
  TRACKING_TOKEN_INVALID // token do Meta expirado ou inválido
  IMPORT_COMPLETE       // importação XLSX concluída
  IMPORT_ERROR          // erro em linha(s) da importação
  LOW_EMAIL_COVERAGE    // muitas leads sem email (match rate em risco)
  SPEED_TO_LEAD         // lead NEW sem primeiro contato (2h / 8h)
  ACTIVATION_ALERT      // lead REGISTERED sem venda (3d / 7d)
  LTV_REACTIVATION      // lead SOLD sem recompra (30d / 60d / 90d)
}

// ─────────────────────────────────────────────────────────────────────────────
// LTV EMAIL — campanhas de reengajamento
// ─────────────────────────────────────────────────────────────────────────────

model EmailTemplate {
  id        String            @id @default(cuid())
  clientId  String?           // null = template padrão do sistema
  name      String
  subject   String
  body      String            @db.Text
  type      EmailTemplateType @default(CUSTOMER)
  isDefault Boolean           @default(false)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  client    Client?           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  logs      LtvEmailLog[]

  @@index([clientId])
}

enum EmailTemplateType {
  CUSTOMER  // email de reengajamento para o comprador
  TEAM      // digest diário para a equipe de vendas
}

model LtvEmailConfig {
  id          String   @id @default(cuid())
  clientId    String   @unique
  enabled     Boolean  @default(false)
  thresholds  Json     // [{ days: 15, templateId: "...", enabled: true }, ...]
  teamEmails  String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model LtvEmailLog {
  id          String       @id @default(cuid())
  clientId    String
  customerId  String?      // null para digest da equipe
  templateId  String?
  type        EmailLogType
  threshold   Int?         // threshold que disparou (15, 20 ou 30 dias)
  messageId   String?      @unique  // ID do Resend para webhook
  sentAt      DateTime     @default(now())
  openedAt    DateTime?
  clickedAt   DateTime?
  bouncedAt   DateTime?

  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  customer    Customer?     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  template    EmailTemplate? @relation(fields: [templateId], references: [id])

  @@index([clientId, customerId, threshold])
  @@index([messageId])
}

enum EmailLogType {
  CUSTOMER  // enviado ao comprador
  TEAM      // digest enviado à equipe
}

// ─────────────────────────────────────────────────────────────────────────────
// LEAD INTERACTION — registro manual de contatos e atividades
// ─────────────────────────────────────────────────────────────────────────────

model LeadInteraction {
  id        String          @id @default(cuid())
  leadId    String
  clientId  String
  type      InteractionType
  content   String
  createdBy String?
  createdAt DateTime        @default(now())

  lead      Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  client    Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([clientId])
}

enum InteractionType {
  NOTE
  CALL
  WHATSAPP
  MEETING
  EMAIL
  OTHER
}
