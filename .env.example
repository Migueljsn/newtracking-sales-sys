# ─── Banco de dados ───────────────────────────────────────────────────────────
# Supabase → Settings → Database → Connection string → Transaction pooler (porta 6543)
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-xx-xxxx-x.pooler.supabase.com:6543/postgres"

# ─── Supabase Auth ────────────────────────────────────────────────────────────
# Supabase → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxxxxxxxxxxxxxx.supabase.co"

# Supabase → Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"

# Supabase → Settings → API → service_role secret (nunca expor no frontend)
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# ─── Tracking worker ──────────────────────────────────────────────────────────
# String aleatória longa para proteger o endpoint do cron
# Gere uma em: https://generate-secret.vercel.app/32
TRACKING_WORKER_SECRET="your_random_secret_here"

# ─── Google Ads ───────────────────────────────────────────────────────────────
# Google Cloud Console → Credenciais → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# Google Ads Manager → Central de APIs → Developer Token
GOOGLE_DEVELOPER_TOKEN="your_developer_token"

# URL base da aplicação (sem barra no final)
NEXT_PUBLIC_APP_URL="https://seu-dominio.vercel.app"
